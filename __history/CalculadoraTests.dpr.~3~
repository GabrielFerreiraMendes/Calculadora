program CalculadoraTests;

{$IFNDEF TESTINSIGHT}
{$APPTYPE CONSOLE}
{$ENDIF}
{$STRONGLINKTYPES ON}

uses
  System.SysUtils,
  {$IFDEF TESTINSIGHT}
  TestInsight.DUnitX,
  {$ELSE}
  DUnitX.Loggers.Console,
  DUnitX.Loggers.Xml.NUnit,
  {$ENDIF }
  DUnitX.TestFramework,
  Test.Calculator.Operation.Addition in 'test\Operations\Test.Calculator.Operation.Addition.pas',
  Test.Calculator.Operation.Subtraction in 'test\Operations\Test.Calculator.Operation.Subtraction.pas',
  Test.Calculator.Operation.Multiplication in 'test\Operations\Test.Calculator.Operation.Multiplication.pas',
  Test.Calculator.Operation.Division in 'test\Operations\Test.Calculator.Operation.Division.pas',
  Test.Calculator.Factory in 'test\Factory\Test.Calculator.Factory.pas',
  Test.Calculator.Engine in 'test\Engine\Test.Calculator.Engine.pas',
  Calculator.Strategy in 'src\Interfaces\Calculator.Strategy.pas',
  Calculator.Operation.Addition in 'src\Operations\Calculator.Operation.Addition.pas';

{$IFNDEF TESTINSIGHT}
var
  runner: ITestRunner;
  results: IRunResults;
  logger: ITestLogger;
  nunitLogger : ITestLogger;
{$ENDIF}

begin
{$IFDEF TESTINSIGHT}
  TestInsight.DUnitX.RunRegisteredTests;
{$ELSE}
  try
    // Verifica log do Memory Leak (Opcional, mas util)
    ReportMemoryLeaksOnShutdown := True;
    
    // Cria o test runner
    runner := TDUnitX.CreateRunner;
    
    // Configura os logs (Console)
    runner.UseRTTI := True;
    
    // Diz para logar no Console
    logger := TDUnitXConsoleLogger.Create(True);
    runner.AddLogger(logger);
    
    // Diz para gerar NUnit XML report
    nunitLogger := TDUnitXXMLNUnitFileLogger.Create(TDUnitX.Options.XMLOutputFile);
    runner.AddLogger(nunitLogger);

    // Roda os testes
    results := runner.Execute;
    if not results.AllPassed then
      System.ExitCode := EXIT_ERRORS;

    {$IFNDEF CI}
    // Pausa no final para visualizacao ao rodar via Delphi IDE
    System.Write('Done.. press <Enter> key to quit.');
    System.Readln;
    {$ENDIF}
  except
    on E: Exception do
      System.Writeln(E.ClassName, ': ', E.Message);
  end;
{$ENDIF}
end.
